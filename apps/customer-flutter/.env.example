# Flutter: pass via --dart-define (see scripts/run-android.sh)

# Linux / desktop / iOS simulator (default after fix):
# API_BASE_URL=http://127.0.0.1:4010/api/v1

# Android emulator:
# API_BASE_URL=http://10.0.2.2:4010/api/v1

# Physical phone on same Wi‑Fi (replace with your PC IP):
# API_BASE_URL=http://192.168.1.100:4010/api/v1

# Prod-local Kong:
# API_BASE_URL=http://127.0.0.1:8000/api/v1

# 1. Start API: npm run mock:dev   (from repo root)
# 2. flutter run
